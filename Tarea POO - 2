Garaje.java
public class Garaje {
    private Coche coche;
    private String averiaAsociada;
    private int cochesAtendidos;

    public Garaje() {
        this.coche = null;
        this.averiaAsociada = "";
        this.cochesAtendidos = 0;
    }

    public Coche getCoche() {
        return coche;
    }

    public String getAveriaAsociada() {
        return averiaAsociada;
    }

    public int getCochesAtendidos() {
        return cochesAtendidos;
    }

    public boolean aceptarCoche(Coche coche, String averiaAsociada) {
        if (this.coche != null) {
            return false;
        }

        this.coche = coche;
        this.averiaAsociada = averiaAsociada;
        this.cochesAtendidos++;
        return true;
    }

    public void devolverCoche() {
        this.coche = null;
        this.averiaAsociada = "";
    }
}

