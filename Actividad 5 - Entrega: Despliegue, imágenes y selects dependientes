import { useState } from "react";
import laptopImagen from "./assets/laptops.webp";
import "./App.css";

const marcasPorDispositivo = {
  Laptop: ["Dell", "HP", "Lenovo", "Apple", "Asus"],

  "Computadora de escritorio": [
    "Dell",
    "HP",
    "Lenovo",
    "Acer",
  ],

  Monitor: ["Samsung", "LG", "Dell", "AOC"],

  Impresora: ["HP", "Epson", "Canon", "Brother"],

  Router: ["Cisco", "Ubiquiti", "TP-Link", "MikroTik"],
};

function App() {
  const [sesionIniciada, setSesionIniciada] = useState(false);

  const [correo, setCorreo] = useState("");
  const [contrasena, setContrasena] = useState("");
  const [errorLogin, setErrorLogin] = useState("");

  const [codigo, setCodigo] = useState("");
  const [dispositivo, setDispositivo] = useState("");
  const [marca, setMarca] = useState("");
  const [estado, setEstado] = useState("");

  const marcasDisponibles = dispositivo
    ? marcasPorDispositivo[dispositivo]
    : [];

  const iniciarSesion = (evento) => {
    evento.preventDefault();

    if (
      correo === "admin@inventario.com" &&
      contrasena === "1234"
    ) {
      setSesionIniciada(true);
      setErrorLogin("");
    } else {
      setErrorLogin("Correo o contraseña incorrectos.");
    }
  };

  const cerrarSesion = () => {
    setSesionIniciada(false);
    setCorreo("");
    setContrasena("");
    setErrorLogin("");

    setCodigo("");
    setDispositivo("");
    setMarca("");
    setEstado("");
  };

  const cambiarDispositivo = (evento) => {
    setDispositivo(evento.target.value);
    setMarca("");
    setEstado("");
  };

  const cambiarMarca = (evento) => {
    setMarca(evento.target.value);
    setEstado("");
  };

  if (!sesionIniciada) {
    return (
      <main className="login-contenedor">
        <section className="login-tarjeta">
          <div className="login-icono">💻</div>

          <h1>Inventario Tecnológico</h1>

          <p>
            Inicia sesión para administrar los activos tecnológicos.
          </p>

          <form
            className="login-formulario"
            onSubmit={iniciarSesion}
          >
            <div className="login-campo">
              <label htmlFor="correo">
                Correo electrónico
              </label>

              <input
                id="correo"
                type="email"
                placeholder="admin@inventario.com"
                value={correo}
                onChange={(evento) =>
                  setCorreo(evento.target.value)
                }
                required
              />
            </div>

            <div className="login-campo">
              <label htmlFor="contrasena">
                Contraseña
              </label>

              <input
                id="contrasena"
                type="password"
                placeholder="Ingresa tu contraseña"
                value={contrasena}
                onChange={(evento) =>
                  setContrasena(evento.target.value)
                }
                required
              />
            </div>

            {errorLogin && (
              <p className="login-error">
                {errorLogin}
              </p>
            )}

            <button
              type="submit"
              className="boton-login"
            >
              Iniciar sesión
            </button>
          </form>

          <div className="credenciales-prueba">
            <strong>Credenciales de prueba</strong>
            <span>admin@inventario.com</span>
            <span>Contraseña: 1234</span>
          </div>
        </section>
      </main>
    );
  }

  return (
    <main className="contenedor">
      <section className="tarjeta">
        <div className="barra-superior">
          <button
            type="button"
            className="boton-cerrar"
            onClick={cerrarSesion}
          >
            Cerrar sesión
          </button>
        </div>

        <h1>Inventario de Activos Tecnológicos</h1>

        <p className="descripcion">
          Registro básico de equipos con imágenes desde public y src,
          y un select dependiente.
        </p>

        <div className="imagenes">
          <div className="imagen-contenedor">
            <h2>Imagen desde public</h2>

            <img
              src="/servidor.jpg"
              alt="Servidor cargado desde public"
            />

            <p>public/servidor.jpg</p>
          </div>

          <div className="imagen-contenedor">
            <h2>Imagen desde src</h2>

            <img
              src={laptopImagen}
              alt="Laptops cargadas desde src"
            />

            <p>src/assets/laptops.webp</p>
          </div>
        </div>

        <div className="formulario">
          <div className="campo">
            <label htmlFor="codigo">
              Código del activo
            </label>

            <input
              id="codigo"
              type="text"
              placeholder="Ejemplo: ACT-001"
              value={codigo}
              onChange={(evento) =>
                setCodigo(evento.target.value)
              }
            />
          </div>

          <div className="campo">
            <label htmlFor="dispositivo">
              Tipo de dispositivo
            </label>

            <select
              id="dispositivo"
              value={dispositivo}
              onChange={cambiarDispositivo}
            >
              <option value="">
                -- Selecciona un dispositivo --
              </option>

              {Object.keys(marcasPorDispositivo).map(
                (tipoDispositivo) => (
                  <option
                    key={tipoDispositivo}
                    value={tipoDispositivo}
                  >
                    {tipoDispositivo}
                  </option>
                )
              )}
            </select>
          </div>

          <div className="campo">
            <label htmlFor="marca">
              Marca
            </label>

            <select
              id="marca"
              value={marca}
              onChange={cambiarMarca}
              disabled={!dispositivo}
            >
              <option value="">
                {dispositivo
                  ? "-- Selecciona una marca --"
                  : "-- Primero selecciona un dispositivo --"}
              </option>

              {marcasDisponibles.map((nombreMarca) => (
                <option
                  key={nombreMarca}
                  value={nombreMarca}
                >
                  {nombreMarca}
                </option>
              ))}
            </select>
          </div>

          <div className="campo">
            <label htmlFor="estado">
              Estado del equipo
            </label>

            <select
              id="estado"
              value={estado}
              onChange={(evento) =>
                setEstado(evento.target.value)
              }
              disabled={!marca}
            >
              <option value="">
                {marca
                  ? "-- Selecciona un estado --"
                  : "-- Primero selecciona una marca --"}
              </option>

              <option value="Disponible">
                Disponible
              </option>

              <option value="Asignado">
                Asignado
              </option>

              <option value="En mantenimiento">
                En mantenimiento
              </option>

              <option value="Fuera de servicio">
                Fuera de servicio
              </option>
            </select>
          </div>
        </div>

        {codigo && dispositivo && marca && estado && (
          <div className="resultado">
            <h2>Activo agregado satisfactoriamente</h2>

            <p className="mensaje-exito">
              El activo tecnológico fue registrado con la siguiente
              información:
            </p>

            <p>
              Código del activo: <strong>{codigo}</strong>
            </p>

            <p>
              Tipo de dispositivo:{" "}
              <strong>{dispositivo}</strong>
            </p>

            <p>
              Marca: <strong>{marca}</strong>
            </p>

            <p>
              Estado del equipo: <strong>{estado}</strong>
            </p>
          </div>
        )}
      </section>
    </main>
  );
}

export default App;
